files:
    "/sbin/appstart":
        mode: "000755"
        owner: webapp
        group: webapp
        content: |
            #!/usr/bin/env bash
            JAR_PATH=/var/app/current/application.jar

            # run app
            killall java 2>/dev/null || true
            java -Dfile.encoding=UTF-8 \
                 -Xms256m -Xmx512m \
                 -Dspring.profiles.active=dev \
                 -jar $JAR_PATH
